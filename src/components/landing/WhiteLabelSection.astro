---
import { Image } from 'astro:assets';
import acceptImage from '../../assets/accept.png';
import screen1Image from '../../assets/screen1.png';
import screen2Image from '../../assets/screen2.png';
import screen3Image from '../../assets/screen3.png';
---
      <!-- New Section: CarniApp se pone tu camiseta -->
      <div id="white-label" class="mt-16 grid lg:grid-cols-2 gap-12 items-center max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <!-- Text Content -->
        <div class="order-2 lg:order-1">
          <h2 class="text-base text-black font-bold tracking-wide uppercase mb-2 text-center">Marca blanca</h2>
          <h2 class="text-4xl lg:text-6xl font-extrabold text-black mb-6 leading-tight">
            CarniApp se pone <br />
            <span class="text-primary text-5xl lg:text-8xl drop-shadow-[0_2px_2px_rgba(0,0,0,0.5)]">tu camiseta</span>
          </h2>
          <p class="text-2xl text-gray-600 mb-8 leading-relaxed">
            Personalizamos la experiencia para que tu marca brille. Desde los colores hasta el logo, todo está diseñado para que tus clientes sientan que están comprando directamente en su carnicería de confianza, con la tecnología más avanzada.
          </p>
          <ul class="space-y-4">
            {[
              "Tu marca, tus colores, tu logo, tu personalización",
              "Catálogo autoadministrable",
              "Soporte técnico dedicado"
            ].map(item => (
              <li class="flex items-center gap-3">
                <Image src={acceptImage} alt="Plus" class="w-8 h-8 object-contain" />
                <span class="text-gray-500 font-bold text-xl">{item}</span>
              </li>
            ))}
          </ul>
        </div>
        
        <!-- Phone Slideshow -->
        <div class="order-1 lg:order-2 flex justify-center">
          <div class="relative w-[280px] h-[590px] bg-dark rounded-2xl border-[3px] border-gray-900 shadow-2xl shadow-primary/30 overflow-hidden">
             <!-- Hole Punch Camera -->
             <div class="absolute top-2 w-3 h-3 bg-black left-1/2 transform -translate-x-1/2 rounded-full z-20 border border-gray-800"></div>
             
             <!-- Slideshow Container -->
             <div class="relative w-full h-full bg-gray-100">
               <Image src={screen1Image} alt="Screen 1" class="absolute inset-0 w-full h-full object-cover animate-slideshow" style="animation-delay: 0s;" />
               <Image src={screen2Image} alt="Screen 2" class="absolute inset-0 w-full h-full object-cover animate-slideshow" style="animation-delay: 3s;" />
               <Image src={screen3Image} alt="Screen 3" class="absolute inset-0 w-full h-full object-cover animate-slideshow" style="animation-delay: 6s;" />
             </div>
          </div>
        </div>
      </div>

<style>
  @keyframes slideshow {
    0% { opacity: 0; }
    10% { opacity: 1; }
    40% { opacity: 1; }
    50% { opacity: 0; }
    100% { opacity: 0; }
  }
  .animate-slideshow {
    animation: slideshow 9s infinite;
  }
</style>
