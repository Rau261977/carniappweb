---
import { Image } from 'astro:assets';
import masImage from '../../assets/mas.png';
import relojImage from '../../assets/reloj.png';
import appImage from '../../assets/app.png';
import intelligenceImage from '../../assets/intelligence.png';
import retencionImage from '../../assets/retencion.png';
import rentabilidadImage from '../../assets/rentabilidad.png';
import deliveryImage from '../../assets/delivery.png';
import FranchiseIcons from './FranchiseIcons.astro';

const features = [
  {
    title: "Optimización de los recursos",
    desc: "Mantener un local comercial abierto, con empleados esperando que los clientes entren es un costo enorme. Con Carniapp los clientes compran on line para recibir o retirar y el canal de comunicación con sus clientes es exclusivo y siempre abierto.",
    icon: relojImage
  },
  {
    title: "Asistente Virtual Especializado",
    desc: "Atención al cliente 24/7 con nuestro asistente IA. 'Rogelio' interactúa de forma inteligente, resuelve dudas frecuentes en tiempo real, sugiere productos basados en preferencias y guía a tus usuarios en una experiencia de compra asistida y sin fricciones.",
    icon: appImage
  },
  {
    title: "Marketing Generativo, Predictivo y Preventivo",
    desc: "Impulsá tus ventas con un motor de IA de última generación. Nuestra tecnología Generativa crea campañas dinámicas, el análisis Predictivo anticipa la demanda de tus clientes, y el enfoque Preventivo detecta automáticamente patrones de abandono para reactivar clientes antes de que dejen de comprar.",
    icon: intelligenceImage
  },
  {
    title: "+ retención \n+ recurrencia",
    desc: "El 87% de los consumidores habituales de carne compra donde le queda más cómodo y la compra en línea es la que más gusta. Según nuestras encuestas.\nEs lo que brinda Carniapp a sus clientes, comprar más comodamente.",
    icon: retencionImage
  },
  {
    title: "+ rentabilidad \n+ alcance",
    desc: "Carniapp digitaliza su negocio, puede acotar horarios de apertura, reducción de tiempos muertos del personal, + ventas + eficiencia + ganancias. \nLlegue a gente más allá de los límites barriales",
    icon: rentabilidadImage
  },
  {
    title: "Logística y Entregas Flexibles",
    desc: "CarniApp ofrece una solución logística integral y adaptable. Integrá servicios externos de delivery o utilizá nuestra propia infraestructura de App de Delivery dedicada. Optimizá rutas, realizá seguimiento en tiempo real y gestioná múltiples puntos de retiro de forma eficiente.",
    icon: deliveryImage
  }
];
---

<section id="features" class="py-4 pt-8 md:pt-4">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Sección Franquicias (Nuevo) -->
    <div class="mb-20">
      <div class="text-center max-w-4xl mx-auto mb-12">
        <span class="text-black font-bold text-sm tracking-wider uppercase mb-2 block">Expansión Corporativa</span>
        <h2 class="text-4xl md:text-5xl font-extrabold text-black mb-4 leading-tight">
          La plataforma perfecta para integrar 
          <span class="relative inline-block">sucursales<svg class="absolute w-full h-3 -bottom-1 left-0 text-primary z-[-1]" viewBox="0 0 200 9" preserveAspectRatio="none"><path d="M0 5 L200 5" stroke="currentColor" stroke-width="6" fill="none" stroke-linecap="round"/></svg></span>
          y
          <span class="relative inline-block">franquicias<svg class="absolute w-full h-3 -bottom-1 left-0 text-primary z-[-1]" viewBox="0 0 200 9" preserveAspectRatio="none"><path d="M0 5 L200 5" stroke="currentColor" stroke-width="6" fill="none" stroke-linecap="round"/></svg></span>
        </h2>
        <p class="text-xl text-gray-600 bg-white/50 backdrop-blur-sm inline-block px-4 py-1 rounded-full">Esperar a que los clientes lleguen es asunto del pasado, con CarniApp tus clientes tienen tu carnicería en el celular</p>
      </div>
      
      <div class="grid md:grid-cols-3 gap-8">
        <!-- Centralización -->
        <div class="bg-white p-8 rounded-3xl shadow-xl shadow-primary/30 border border-gray-100 relative group overflow-hidden hover:-translate-y-1 transition-all duration-300">
            <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-br from-primary/20 to-transparent rounded-bl-full -mr-10 -mt-10 transition-transform group-hover:scale-150 duration-500 ease-out"></div>
            <FranchiseIcons icon="phone" size={32} className="absolute top-4 right-4 bg-[#333] p-2 rounded-2xl text-primary z-20" />
            <h3 class="text-3xl font-bold text-dark mb-3 relative z-10">Una app para<br>todas tus sucursales</h3>
            <p class="text-gray-600 leading-relaxed relative z-10">
              Que un cliente se vaya de uno de tus locales con las manos vacías puede representar la pérdida de un cliente, con Carniapp tus clientes puden recorrer todas tus sucursales desde tu aplicación. Minimizando compartir clientes con otra marca.
            </p>
        </div>

        <!-- Identidad -->
        <div class="bg-white p-8 rounded-3xl shadow-xl shadow-primary/30 border border-gray-100 relative group overflow-hidden hover:-translate-y-1 transition-all duration-300">
            <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-br from-primary/20 to-transparent rounded-bl-full -mr-10 -mt-10 transition-transform group-hover:scale-150 duration-500 ease-out"></div>
            <FranchiseIcons icon="brand" size={32} className="absolute top-4 right-4 bg-[#333] p-2 rounded-2xl text-primary z-20" />
            <h3 class="text-3xl font-bold text-dark mb-3 relative z-10">Higiene<br>Digital</h3>
            <p class="text-gray-600 leading-relaxed relative z-10">
              Un ecosistema digital independiente que elimina “ruido competitivo”. Tu carnicería opera en una app única, con identidad personalizada y sin marcas similares compartiendo el mismo espacio.
            </p>
        </div>

        <!-- Escalabilidad -->
        <div class="bg-white p-8 rounded-3xl shadow-xl shadow-primary/30 border border-gray-100 relative group overflow-hidden hover:-translate-y-1 transition-all duration-300">
             <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-br from-primary/20 to-transparent rounded-bl-full -mr-10 -mt-10 transition-transform group-hover:scale-150 duration-500 ease-out"></div>
            <FranchiseIcons icon="growth" size={32} className="absolute top-4 right-4 bg-[#333] p-2 rounded-2xl text-primary z-20" />
            <h3 class="text-3xl font-bold text-dark mb-3 relative z-10">Escalabilidad <br>Sin Dolor</h3>
            <p class="text-gray-600 leading-relaxed relative z-10">
            Aumenta el volumen de ventas con inteligencia y tecnología.<br> Más ventas con menos esfuerzo.<br> Escalamiento vertical aumentando las ventas de cada unidad de tu marca.<br> Escala horizontalmente integrando más unidades robustamente.</p>
        </div>
      </div>
    </div>
    <div class="text-center max-w-3xl mx-auto mb-8">
      <h2 class="text-base text-black font-bold tracking-wide uppercase mb-2">Características</h2>
      <p class="text-5xl font-extrabold text-black mb-2"><Image src={masImage} alt="Más beneficios" class="w-16 h-16 inline" width={80} height={80} /> que una app de delivery <br> <Image src={masImage} alt="Más beneficios" class="w-16 h-16 inline" width={80} height={80} /> que una carnicería</p>
      <p class="text-2xl text-gray-600">Tecnología para darle la mejor experiencia de compra al cliente</p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {features.map(feature => (
        <div class="bg-white p-8 rounded-2xl shadow-lg shadow-primary/30 border border-gray-100 hover:shadow-xl hover:shadow-primary/30 transition-all hover:transform hover:-translate-y-1 group">
          <div class="flex items-center gap-4 mb-3">
              <div class="w-14 h-14 rounded-xl flex items-center justify-center text-3xl group-hover:scale-110 transition-transform bg-transparent">
                <Image src={feature.icon} alt={feature.title} class="w-full h-full object-contain scale-[1.15]" width={80} height={80} />
              </div>
            <div class="flex-1">
              <h3 class="text-2xl font-bold text-dark whitespace-pre-line leading-tight">{feature.title}</h3>
            </div>
          </div>
          <p class="text-gray-600 leading-relaxed whitespace-pre-line">{feature.desc}</p>
        </div>
      ))}
    </div>
    
  <!-- Información importante -->
  <div class="flex mt-16 justify-center p-5">
    <Image 
      src="https://res.cloudinary.com/dkxj30sue/image/upload/f_auto,q_auto/v1767029167/concepto_hmdusm.png" 
      alt="Concepto CarniApp: App y Dashboard" 
      width={1200} 
      height={900} 
      class="max-w-full h-auto rounded-3xl border-2 border-black shadow-lg p-[20px] block md:hidden" 
      loading="lazy"
    />
    <Image 
      src="https://res.cloudinary.com/dkxj30sue/image/upload/f_auto,q_auto/v1766714023/concepto_fn4a6c.webp" 
      alt="Ecosistema Digital CarniApp" 
      width={1200} 
      height={900} 
      class="max-w-full h-auto rounded-3xl border-2 border-black shadow-lg hidden md:block" 
      loading="lazy"
    />
  </div>

  </div>
</section>
```
