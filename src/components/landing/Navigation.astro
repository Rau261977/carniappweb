---
import { Image } from 'astro:assets';
import iconImage from '../../assets/icon.png';
---
<nav class="fixed w-full z-50 bg-white/90 backdrop-blur-md border-b border-gray-100 transition-all duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20">
      <div class="flex items-center gap-2">
        <Image src={iconImage} alt="CarniApp Logo" class="h-12 w-12 rounded-lg shadow-sm" loading="eager" />
          <span class="hidden md:inline text-2xl tracking-tight text-dark">CarniApp</span>
      </div>
      <div class="hidden md:flex space-x-8">
        <a href="#features" class="text-black hover:text-primary font-semibold transition-colors">Características</a>
        <a href="#white-label" class="text-black hover:text-primary font-semibold transition-colors">Marca blanca</a>
        <a href="#mmi" class="text-black hover:text-primary font-semibold transition-colors">MMI</a>
        <a href="#how-it-works" class="text-black hover:text-primary font-semibold transition-colors">Como trabajamos</a>
        <a href="#faq" class="text-black hover:text-primary font-semibold transition-colors">Preguntas</a>
      </div>
      <div class="flex items-center gap-3">
        <a 
          href="https://wa.me/542213632191" 
          target="_blank"
          rel="noopener noreferrer"
          class="transition-transform transform hover:scale-110 active:scale-95"
          aria-label="Contactar por WhatsApp"
        >
          <img src="/whatsapp_1383269.png" alt="WhatsApp" class="w-10 h-10 md:w-10 md:h-10 object-contain" />
        </a>
        <a 
          href="https://github.com/Rau261977/carniapp-lanzamiento/releases/download/v1.0.2/carniapp.apk" 
          class="flex items-center gap-2 bg-primary hover:bg-primary-dark text-dark font-bold py-3 px-6 rounded-full shadow-lg transition-all transform hover:scale-105"
        >
          <!-- Icono de Android -->
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" role="img" xmlns="http://www.w3.org/2000/svg">
            <path d="M17.523 15.3414c-.5511 0-.9993-.4486-.9993-.9997s.4482-.9993.9993-.9993c.5511 0 .9993.4482.9993.9993.0001.5511-.4482.9997-.9993.9997m-11.046 0c-.5511 0-.9993-.4486-.9993-.9997s.4482-.9993.9993-.9993c.5511 0 .9993.4482.9993.9993 0 .5511-.4482.9997-.9993.9997m11.4045-6.02l1.9973-3.4592a.416.416 0 00-.1521-.5676.416.416 0 00-.5676.1521l-2.0223 3.503C15.5902 8.0133 13.852 7.589 12 7.589s-3.5902.4243-5.1367 1.3627L4.841 5.4487a.416.416 0 00-.5676-.1521.416.416 0 00-.1521.5676l1.9973 3.4592C2.6889 11.1867.3432 14.6589 0 18.761h24c-.3432-4.1021-2.6889-7.5743-6.1185-9.4396"/>
          </svg>
          <span class="hidden md:inline text-sm md:text-base">Descargar App</span>
        </a>
      </div>
    </div>
  </div>
</nav>
