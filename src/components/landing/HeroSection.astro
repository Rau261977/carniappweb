---
import { Image } from 'astro:assets';
import appleImage from '../../assets/apple.png';
import playstoreImage from '../../assets/playstore.png';
---
<section class="pt-24 lg:pt-18 overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-8 lg:px-8 relative">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-8 items-center">
      
      <!-- Text Content -->
      <div class="text-center lg:text-left z-10">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-yellow-100 text-yellow-800 text-sm font-semibold mb-6 animate-fade-in-up">
          <span class="w-2 h-2 rounded-full bg-yellow-500"></span>
          Motor de marketing y ventas
        </div>
        
        <h1 class="text-5xl lg:text-7xl font-extrabold tracking-tight text-black mb-6 leading-tight">
          El futuro de la <br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-orange-500 drop-shadow-[0_2px_2px_rgba(0,0,0,0.5)]">carnicería</span>
        </h1>
        
        <p class="text-xl text-gray-600 mb-10 leading-relaxed max-w-2xl mx-auto lg:mx-0">
          Esperar a que los clientes lleguen es asunto del pasado, con <strong>CarniApp</strong> tus clientes tienen tu carnicería en el celular 
          y el negocio trabaja más eficientemente con envíos o retiros.
        </p>
        
        <div class="flex flex-row gap-4 justify-center lg:justify-start" id="download">
          <a href="#" class="transition-transform hover:scale-105 hover:opacity-90">
            <Image src={appleImage} alt="App Store" class="h-12 lg:h-16 w-auto" />
          </a>
          
          <a href="#" class="transition-transform hover:scale-105 hover:opacity-90">
            <Image src={playstoreImage} alt="Google Play" class="h-12 lg:h-16 w-auto" />
          </a>
        </div>
        
        <div class="mt-8 flex items-center justify-center lg:justify-start gap-4 text-sm text-gray-500">
          <div class="flex -space-x-2">
            {[1,2,3,4].map(i => (
              <div class={`w-8 h-8 rounded-full border-2 border-white bg-gray-200 flex items-center justify-center overflow-hidden`}>
                 <span class="text-xs">👤</span>
              </div>
            ))}
          </div>
          <p>millones de carnívoros felices</p>
        </div>
      </div>

      <!-- Phone Mockup -->
      <div class="relative z-10 flex items-center justify-center animate-float lg:flex">
        <div class="relative w-[320px] h-[670px] bg-dark rounded-2xl border-[3px] border-gray-900 shadow-2xl shadow-primary/30 overflow-hidden scale-[0.85]">
           <!-- Hole Punch Camera -->
           <div class="absolute top-2 w-3 h-3 bg-black left-1/2 transform -translate-x-1/2 rounded-full z-20 border border-gray-800"></div>
           
           <!-- Screen Content: Video -->
           <div class="w-full h-full bg-black">
              <video 
                class="w-full h-full object-cover" 
                autoplay 
                loop 
                muted 
                playsinline
              >
                <source src="https://res.cloudinary.com/dkxj30sue/video/upload/v1766711365/demo_we8irq.mp4" type="video/mp4" />
                <source src="/demo.mp4" type="video/mp4" />
                <track kind="captions" src="/captions.vtt" srclang="es" label="Español" default />
              </video>
           </div>
        </div>
        
        <!-- Background Blobs -->
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-primary/20 rounded-full blur-3xl -z-10 animate-pulse-slow"></div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-20px); }
  }
  .animate-float {
    animation: float 6s ease-in-out infinite;
  }
  
  @keyframes pulse-slow {
    0%, 100% { opacity: 0.2; transform: translate(-50%, -50%) scale(1); }
    50% { opacity: 0.3; transform: translate(-50%, -50%) scale(1.1); }
  }
  .animate-pulse-slow {
    animation: pulse-slow 4s ease-in-out infinite;
  }
</style>
