---
import { Image } from 'astro:assets';
import appleImage from '../../assets/apple.png';
import playstoreImage from '../../assets/playstore.png';
import gpsImage from '../../assets/gps.png';
---
<section class="pt-24 lg:pt-14 overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-8 lg:px-8 relative">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-8 items-center">
      
      <!-- Text Content -->
      <div class="text-center lg:text-left z-10">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-yellow-100 text-yellow-800 text-sm font-semibold mb-6 animate-fade-in-up">
          <span class="w-2 h-2 rounded-full bg-yellow-500"></span>
          Infraestructura Digital para la <strong>Industria Cárnica</strong>
        </div>
        
        <h1 class="text-5xl lg:text-6xl font-extrabold tracking-tight text-black mb-6 leading-tight">
          El futuro de la <br />
          <span class="text-transparent tracking-wider lg:text-8xl bg-clip-text bg-gradient-to-r from-primary to-orange-500 drop-shadow-[0_4px_4px_rgba(0,0,0,0.6)]">carnicería</span>
        </h1>
        
        <p class="text-xl text-gray-600 mb-5 leading-relaxed max-w-2xl mx-auto lg:mx-0">
          Transformamos cualquier carnicería<br> en una empresa moderna, eficiente y digital. 
          <br>
          Una <strong>aplicación exclusiva para tu marca</strong>, combinada con inteligencia comercial, 
          automatización y logística integrada para convertir tu negocio en una empresa moderna.</p>
        
        <!--<div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start" id="action-buttons">
          <a href="https://wa.me/5491130804640?text=Hola,%20me%20interesa%20una%20demo%20de%20CarniApp" target="_blank" rel="noopener noreferrer" class="px-8 py-4 bg-red-600 hover:bg-red-700 text-white font-bold rounded-xl transition-all shadow-lg hover:shadow-red-600/30 flex items-center justify-center gap-2 transform hover:-translate-y-1">
            <span>📅</span> Agendar Demo 15'
          </a>
          <button onclick="document.querySelector('video').scrollIntoView({behavior: 'smooth', block: 'center'})" class="px-8 py-4 bg-white border-2 border-gray-200 hover:border-red-500/30 text-gray-700 hover:text-red-600 font-bold rounded-xl transition-all flex items-center justify-center gap-2">
            <span>▶</span> Ver Tecnología
          </button>
        </div>-->
        
        <div class="flex items-center justify-center lg:justify-start gap-2 text-sm text-gray-600">
          <div class="flex -space-x-2">
              <div class="w-12 h-12 border-2 border-white bg-none flex items-center justify-center overflow-hidden shadow-sm">
                 <Image src={gpsImage} alt="Ubicación GPS" class="w-full h-full object-cover" loading="eager" width={80} height={80} />
              </div>
          </div>
          <p class="text-lg font-bold text-dark leading-snug">Aplicación de delivery integrada. Solo necesitás cortar la carne.</p>
        </div>
      </div>

      <!-- Phone Mockup -->
      <div class="relative z-10 flex items-center justify-center lg:flex">
        <div class="relative w-[320px] h-[670px] bg-dark rounded-2xl border-[3px] border-gray-900 shadow-2xl shadow-primary/30 overflow-hidden scale-[0.85]">
           <!-- Hole Punch Camera -->
           <div class="absolute top-2 w-3 h-3 bg-black left-1/2 transform -translate-x-1/2 rounded-full z-20 border border-gray-800"></div>
           
           <!-- Screen Content: Video -->
           <div class="w-full h-full bg-black">
              <video 
                class="w-full h-full object-cover" 
                autoplay 
                loop 
                muted 
                playsinline
              >
                <source src="https://res.cloudinary.com/dkxj30sue/video/upload/f_auto,q_auto/v1766711365/demo_we8irq.mp4" type="video/mp4" />
                <track kind="captions" src="/captions.vtt" srclang="es" label="Español" default />
              </video>
           </div>
        </div>
        
        <!-- Background Blobs -->
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-primary/20 rounded-full blur-3xl -z-10 animate-pulse-slow"></div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-20px); }
  }
  .animate-float {
    animation: float 6s ease-in-out infinite;
  }
  
  @keyframes pulse-slow {
    0%, 100% { opacity: 0.2; transform: translate(-50%, -50%) scale(1); }
    50% { opacity: 0.3; transform: translate(-50%, -50%) scale(1.1); }
  }
  .animate-pulse-slow {
    animation: pulse-slow 4s ease-in-out infinite;
  }
</style>
