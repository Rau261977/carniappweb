---
import { Image } from "astro:assets";
import facebookImage from "../../assets/facebook.png";
import instagramImage from "../../assets/instagram.png";
import tiktokImage from "../../assets/tiktok.png";
---

<footer class="bg-dark text-white pt-10 pb-1 border-t border-gray-800">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid md:grid-cols-4 gap-8">
    <div class="col-span-2">
      <a
        href="/"
        class="flex items-center gap-2 hover:opacity-80 transition-opacity"
      >
        <!--  <span class="text-3xl">🥩</span> -->
        <span class="font-bold text-2xl">CarniApp</span>
      </a>
      <p class="text-gray-400 max-w-xs mb-3 whitespace-pre-line">
        La revolución de la carne. El futuro de las carnicerías.
      </p>
    </div>
    <div>
      <h2 class="font-bold text-lg mb-2">Legal</h2>
      <ul class="space-y-2 text-gray-300">
        <li>
          <a href="/terminos" class="hover:text-primary transition-colors"
            >Términos y Condiciones</a
          >
        </li>
        <li>
          <a href="/blog/" class="hover:text-primary transition-colors">Blog</a>
        </li>
        <li>
          <a href="/privacidad" class="hover:text-primary transition-colors"
            >Privacidad</a
          >
        </li>
      </ul>
    </div>
    <div>
      <h2 class="font-bold text-lg mb-1 md:mb-4">Seguinos</h2>
      <div class="flex space-x-4 -mt-1 md:mt-10">
        <a
          href="https://www.instagram.com/carniapp/"
          target="_blank"
          rel="noopener noreferrer"
          class="w-10 h-10 bg-gray-800 rounded-full flex items-center justify-center hover:bg-primary hover:text-dark transition-all font-bold overflow-hidden p-2"
          onclick="gtag('event', 'social_click', { 'event_category': 'engagement', 'event_label': 'instagram_footer' });"
        >
          <Image
            src={instagramImage}
            alt="Instagram"
            class="w-full h-full object-contain"
          />
        </a>
        <a
          href="https://www.facebook.com/profile.php?id=61585867845622"
          target="_blank"
          rel="noopener noreferrer"
          class="w-10 h-10 bg-gray-800 rounded-full flex items-center justify-center hover:bg-primary hover:text-dark transition-all font-bold overflow-hidden p-2"
          onclick="gtag('event', 'social_click', { 'event_category': 'engagement', 'event_label': 'facebook_footer' });"
        >
          <Image
            src={facebookImage}
            alt="Facebook"
            class="w-full h-full object-contain"
          />
        </a>
        <a
          href="https://www.tiktok.com/@carniapp"
          target="_blank"
          rel="noopener noreferrer"
          class="w-10 h-10 bg-gray-800 rounded-full flex items-center justify-center hover:bg-primary hover:text-dark transition-all font-bold overflow-hidden p-2"
          onclick="gtag('event', 'social_click', { 'event_category': 'engagement', 'event_label': 'tiktok_footer' });"
        >
          <Image
            src={tiktokImage}
            alt="TikTok"
            class="w-full h-full object-contain"
          />
        </a>
        <a
          href="mailto:admin@carniapp.com"
          class="w-10 h-10 bg-gray-800 rounded-full flex items-center justify-center hover:bg-primary hover:text-dark transition-all font-bold overflow-hidden p-1"
          title="Enviar correo"
          aria-label="Enviar correo"
          onclick="gtag('event', 'contact', { 'event_category': 'engagement', 'event_label': 'email_footer' });"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="w-full h-full p-1"
            ><rect width="20" height="16" x="2" y="4" rx="2"></rect><path
              d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg
          >
        </a>
      </div>
    </div>
  </div>
  <div
    class="border-t border-gray-800 mt-1 pt-1 text-center text-gray-300 text-sm"
  >
    &copy; {new Date().getFullYear()} CarniApp.
  </div>
</footer>
