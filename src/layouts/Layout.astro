---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  type?: "website" | "article";
  articleData?: {
    author: string;
    pubDate: Date;
  };
}

const {
  title,
  description = "CarniApp - El Sistema Operativo para Carnicerías Modernas. Aumenta tus ventas y fideliza clientes con tu propia App Inteligente.",
  ogImage = "https://carniapp.com/icon.png",
  type = "website",
  articleData,
} = Astro.props;
import ChatWidget from "../components/ChatWidget";
import SEO from "../components/landing/SEO.astro";
import "../styles/global.css";
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <!-- Google tag (gtag.js) -->
    <script is:inline>
      // Sistema de exclusión para el desarrollador
      const GA_ID = "G-K2GKDGK2CE";
      const OPT_OUT_KEY = "ga_opt_out";
      const urlParams = new URLSearchParams(window.location.search);

      // Si se visita la web con ?exclude_me=true, se activa la exclusión permanente en este navegador
      if (urlParams.get("exclude_me") === "true") {
        localStorage.setItem(OPT_OUT_KEY, "true");
        alert("Exclusión de Analytics activada para este navegador.");
      }

      // Si la exclusión está activa o estamos en local, desactivamos GA globalmente
      if (
        localStorage.getItem(OPT_OUT_KEY) === "true" ||
        window.location.hostname === "localhost" ||
        window.location.hostname === "127.0.0.1"
      ) {
        window[`ga-disable-${GA_ID}`] = true;
        console.log("Google Analytics deshabilitado (Modo desarrollador/Local)");
      }
    </script>
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-K2GKDGK2CE"
    ></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());

      gtag("config", "G-K2GKDGK2CE");
    </script>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="icon" type="image/png" href="/icon.png" />
    <link rel="apple-touch-icon" href="/icon.png" />
    <meta name="generator" content={Astro.generator} />

    <!-- Preconnect a dominios externos -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Preload de fuentes críticas -->
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Urbanist:wght@400;500;600;700;800&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Urbanist:wght@400;500;600;700;800&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Urbanist:wght@400;500;600;700;800&display=swap"
      />
    </noscript>
    <link rel="preconnect" href="https://api-production-531f.up.railway.app" />
    <link rel="canonical" href={`https://carniapp.com${Astro.url.pathname}`} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url.href} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImage} />

    <SEO
      type={type === "article" ? "BlogPosting" : "SoftwareApplication"}
      title={title}
      description={description}
      image={ogImage}
      author={articleData?.author}
      datePublished={articleData?.pubDate.toISOString()}
    />

    <title>{title}</title>
  </head>
  <body class="text-dark antialiased bg-white">
    <slot />
    <ChatWidget client:idle />
  </body>
</html>

<style is:global>
  body {
    font-family: "Urbanist", system-ui, sans-serif;
  }
</style>
