---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/landing/Navigation.astro';
import Footer from '../../components/landing/Footer.astro';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Layout title={`${entry.data.title} | CarniApp`} description={entry.data.description}>
  <Navigation />
  
  <main class="pt-32 pb-20 bg-white">
    <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <a href="/blog/" class="text-primary font-bold hover:underline mb-8 inline-block">← Volver al blog</a>
        <div class="flex items-center gap-2 mb-6">
          {entry.data.tags.map(tag => (
            <span class="px-3 py-1 bg-yellow-100 text-yellow-800 text-xs font-bold rounded-full uppercase tracking-wider">
              {tag}
            </span>
          ))}
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-dark mb-6 leading-tight">
          {entry.data.title}
        </h1>
        <div class="flex items-center gap-4 text-gray-500 font-medium">
          <span>{entry.data.author}</span>
          <span class="w-1.5 h-1.5 rounded-full bg-gray-300"></span>
          <span>
            {entry.data.pubDate.toLocaleDateString('es-ES', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
          </span>
        </div>
      </div>

      <div class="prose prose-lg lg:prose-xl prose-primary max-w-none 
        prose-headings:text-dark prose-headings:font-bold 
        prose-p:text-gray-600 prose-p:leading-relaxed
        prose-li:text-gray-600
        prose-strong:text-dark prose-strong:font-bold
        prose-a:text-primary prose-a:font-bold hover:prose-a:underline">
        <Content />
      </div>

      <div class="mt-20 p-10 bg-gray-50 rounded-3xl border border-gray-100 text-center">
        <h3 class="text-2xl font-bold text-dark mb-4">¿Querés que tu carnicería sea la próxima en digitalizarse?</h3>
        <p class="text-gray-600 mb-8 max-w-2xl mx-auto">
          CarniApp ayuda a negocios como el tuyo a vender más y fidelizar clientes con tecnología propia.
        </p>
        <a href="https://wa.me/542213632191" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-primary hover:bg-primary-dark text-dark font-bold py-4 px-8 rounded-full shadow-lg transition-all transform hover:scale-105">
          Agendar una demo gratuita
        </a>
      </div>
    </article>
  </main>

  <Footer />
</Layout>
