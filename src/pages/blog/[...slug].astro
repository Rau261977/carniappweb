---
import { getCollection, type CollectionEntry } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Navigation from "../../components/landing/Navigation.astro";
import Footer from "../../components/landing/Footer.astro";

export async function getStaticPaths() {
  const blogEntries = await getCollection("blog");
  const sortedEntries = blogEntries.sort(
    (a: CollectionEntry<"blog">, b: CollectionEntry<"blog">) =>
      b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
  );

  return sortedEntries.map((entry: CollectionEntry<"blog">, index: number) => {
    const prev =
      index < sortedEntries.length - 1 ? sortedEntries[index + 1] : null;
    const next = index > 0 ? sortedEntries[index - 1] : null;
    return {
      params: { slug: entry.slug },
      props: { entry, prev, next },
    };
  });
}

interface Props {
  entry: CollectionEntry<"blog">;
  prev: CollectionEntry<"blog"> | null;
  next: CollectionEntry<"blog"> | null;
}

const { entry, prev, next } = Astro.props;
const { Content } = await entry.render();
---

<Layout
  title={`${entry.data.title} | CarniApp`}
  description={entry.data.description}
  type="article"
  articleData={{
    author: entry.data.author,
    pubDate: entry.data.pubDate,
  }}
>
  <Navigation />

  <main class="pt-32 pb-20 bg-white">
    <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <a
          href="/blog/"
          class="text-primary font-bold hover:underline mb-8 inline-block"
          >← Volver al blog</a
        >
        <div class="flex items-center gap-2 mb-6">
          {
            entry.data.tags.map((tag: string) => (
              <span class="px-3 py-1 bg-yellow-100 text-yellow-800 text-xs font-bold rounded-full uppercase tracking-wider">
                {tag}
              </span>
            ))
          }
        </div>
        <h1
          class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-dark mb-6 leading-tight"
        >
          {entry.data.title}
        </h1>
        <div class="flex items-center gap-4 text-gray-500 font-medium">
          <span>{entry.data.author}</span>
          <span class="w-1.5 h-1.5 rounded-full bg-gray-300"></span>
          <span>
            {
              entry.data.pubDate.toLocaleDateString("es-ES", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })
            }
          </span>
        </div>
      </div>

      <div
        class="prose prose-lg lg:prose-xl prose-primary max-w-none
        prose-headings:text-dark prose-headings:font-bold
        prose-strong:text-dark prose-strong:font-bold
        prose-a:text-primary prose-a:font-bold hover:prose-a:underline
        blog-post-content"
      >
        <Content />
      </div>

      <div class="mt-20 pt-10 border-t border-gray-100">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {
            prev && (
              <a
                href={`/blog/${prev.slug}/`}
                class="group p-8 bg-gray-50 rounded-3xl border border-gray-100 transition-all hover:bg-white hover:shadow-xl hover:-translate-y-1 block"
              >
                <span class="text-gray-400 text-sm font-bold uppercase tracking-widest block mb-2">
                  ← Anterior
                </span>
                <h4 class="text-dark font-bold text-xl group-hover:text-primary transition-colors">
                  {prev.data.title}
                </h4>
              </a>
            )
          }

          {
            next && (
              <a
                href={`/blog/${next.slug}/`}
                class="group p-8 bg-gray-50 rounded-3xl border border-gray-100 transition-all hover:bg-white hover:shadow-xl hover:-translate-y-1 block text-right md:col-start-2"
              >
                <span class="text-gray-400 text-sm font-bold uppercase tracking-widest block mb-2">
                  Siguiente →
                </span>
                <h4 class="text-dark font-bold text-xl group-hover:text-primary transition-colors">
                  {next.data.title}
                </h4>
              </a>
            )
          }
        </div>
      </div>
    </article>
  </main>

  <Footer />
</Layout>

<style is:global>
  :root {
    --h-color-neutral-700: #374151; /* Default value for the variable if not defined elsewhere */
  }

  .blog-post-content p,
  .blog-post-content li {
    color: var(--h-color-neutral-700) !important;
    font-size: 20px !important;
    font-weight: 400 !important;
    letter-spacing: 0.3px !important;
    line-height: 32px !important;
  }

  .blog-post-content h3 {
    color: #111111 !important;
    font-size: 28px !important; /* Aprox 2px más que el prose default o ajustado a la escala */
    font-weight: 800 !important;
    margin-top: 2.5rem !important;
    margin-bottom: 1.5rem !important;
  }

  .blog-post-content img {
    border-radius: 1.5rem;
    margin: 3rem 0;
    box-shadow:
      0 20px 25px -5px rgba(0, 0, 0, 0.1),
      0 10px 10px -5px rgba(0, 0, 0, 0.04);
  }

  .blog-post-content em {
    display: block;
    text-align: center;
    color: #6b7280;
    font-style: italic;
    margin-top: -2rem;
    margin-bottom: 3rem;
  }
</style>
