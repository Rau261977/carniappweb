---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/landing/Navigation.astro';
import Footer from '../../components/landing/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout title="Blog para Carnicerías Modernas | CarniApp">
  <Navigation />
  
  <main class="pt-32 pb-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h1 class="text-5xl font-extrabold text-dark mb-6">Blog para <span class="text-primary drop-shadow-sm">Carnicerías Modernas</span></h1>
        <p class="text-xl text-gray-600">
          Estrategias, tecnología y consejos para llevar tu carnicería al siguiente nivel digital.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map((post) => (
          <article class="bg-white rounded-3xl shadow-xl shadow-primary/10 border border-gray-100 overflow-hidden hover:-translate-y-2 transition-all duration-300 flex flex-col">
            <div class="p-8 flex-1">
              <div class="flex items-center gap-2 mb-4">
                {post.data.tags.map(tag => (
                  <span class="px-3 py-1 bg-yellow-100 text-yellow-800 text-xs font-bold rounded-full uppercase tracking-wider">
                    {tag}
                  </span>
                ))}
              </div>
              <h2 class="text-2xl font-bold text-dark mb-4 leading-tight">
                <a href={`/blog/${post.slug}/`} class="hover:text-primary transition-colors">
                  {post.data.title}
                </a>
              </h2>
              <p class="text-gray-600 mb-6 line-clamp-3">
                {post.data.description}
              </p>
            </div>
            <div class="px-8 py-6 bg-gray-50 border-t border-gray-100 flex justify-between items-center">
              <span class="text-sm text-gray-400 font-medium">
                {post.data.pubDate.toLocaleDateString('es-ES', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </span>
              <a href={`/blog/${post.slug}/`} class="text-primary font-bold hover:text-dark transition-colors flex items-center gap-1">
                Leer más <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</Layout>
