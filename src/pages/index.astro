---
import Layout from '../layouts/Layout.astro';
---

<Layout title="CarniApp - Tu Carnicería Virtual Premium en Casa">
  <!-- Nav -->
  <nav class="fixed w-full z-50 bg-white/90 backdrop-blur-md border-b border-gray-100 transition-all duration-300">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-20">
        <div class="flex items-center gap-2">
          <img src="/icon.png" alt="CarniApp Logo" class="h-10 w-10 rounded-lg shadow-sm" />
          <span class="text-2xl tracking-tight text-dark">CarniApp</span>
        </div>
        <div class="hidden md:flex space-x-8">
          <a href="#features" class="text-gray-600 hover:text-primary font-semibold transition-colors">Características</a>
          <a href="#how-it-works" class="text-gray-600 hover:text-primary font-semibold transition-colors">Cómo funciona</a>
          <a href="#testimonials" class="text-gray-600 hover:text-primary font-semibold transition-colors">Opiniones</a>
        </div>
        <a href="#download" class="bg-primary hover:bg-primary-dark text-dark font-bold py-2.5 px-6 rounded-full transition-all transform hover:scale-105 shadow-lg shadow-primary/30">
          Descargar App
        </a>
      </div>
    </div>
  </nav>

  <!-- Hero Section -->
  <section class="pt-16 lg:pt-24 lg:pb-10 overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-8 items-center">
        
        <!-- Text Content -->
        <div class="text-center lg:text-left z-10">
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-yellow-100 text-yellow-800 text-sm font-semibold mb-6 animate-fade-in-up">
            <span class="w-2 h-2 rounded-full bg-yellow-500"></span>
            Motor de marketing y ventas
          </div>
          
          <h1 class="text-5xl lg:text-7xl font-extrabold tracking-tight text-dark mb-6 leading-tight">
            El futuro de la <br />
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-orange-500">carnicería</span>
          </h1>
          
          <p class="text-xl text-gray-600 mb-10 leading-relaxed max-w-2xl mx-auto lg:mx-0">
            Esperar a que los clientes lleguen es asunto del pasado, con <strong>CarniApp</strong> tus clientes tienen tu carnicería en el celular 
            y el negocio trabaja más eficientemente con envíos o retiros.
          </p>
          
          <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start" id="download">
            <button class="flex items-center justify-center gap-3 bg-dark text-white px-8 py-4 rounded-xl hover:bg-gray-900 transition-all shadow-xl hover:shadow-2xl transform hover:-translate-y-1 w-full sm:w-auto">
              {/* Apple Icon */}
              <svg class="w-8 h-8" viewBox="0 0 24 24" fill="currentColor"><path d="M17.523 15.3414C17.5134 11.6601 20.6698 9.77196 20.8252 9.68233C19.102 7.15935 16.4278 6.78635 15.655 6.72658C13.5678 6.50529 11.5542 7.96541 10.4907 7.96541C9.42721 7.96541 7.82479 6.76644 6.0792 6.78835C3.81979 6.81623 1.74838 8.10682 0.598696 10.0964C-1.76159 14.1866 1.62128 20.1558 3.90543 23.4549C5.01859 25.0645 6.31557 26.8373 8.04603 26.7715C9.69677 26.7038 10.3204 25.717 12.3157 25.717C14.2882 25.717 14.8692 26.7715 16.6394 26.7496C18.4336 26.7038 19.5677 25.1084 20.6628 23.5008C21.9168 21.6669 22.4281 19.8946 22.455 19.805C22.4082 19.7821 17.5519 17.9268 17.523 15.3414ZM11.8315 4.60623C12.721 3.52735 13.3158 2.03157 13.1534 0.535805C11.8594 0.588636 10.2974 1.40026 9.38742 2.45585C8.57099 3.39088 7.85406 4.90928 8.04603 6.37877C9.48908 6.49137 10.9413 5.68474 11.8315 4.60623Z" transform="translate(0 -1) scale(0.8)"/></svg>
              <div class="text-left">
                <div class="text-xs uppercase font-medium text-gray-400">Consíguelo en el</div>
                <div class="text-lg font-bold">App Store</div>
              </div>
            </button>
            
            <button class="flex items-center justify-center gap-3 bg-dark text-white px-8 py-4 rounded-xl hover:bg-gray-900 transition-all shadow-xl hover:shadow-2xl transform hover:-translate-y-1 w-full sm:w-auto">
              {/* Google Play Icon */}
              <svg class="w-8 h-8" viewBox="0 0 24 24" fill="currentColor"><path d="M3.609 1.814L13.792 12 3.61 22.186a2.49 2.49 0 01-1.258-3.08l1.41-8.084-1.428-8.158c-.14-.793.109-1.61.677-2.05zM15.42 12l5.772 3.237c1.028.577 1.028 2.023 0 2.6l-2.094-1.173L15.42 12zm0 0l3.678-5.336L21.192 7.8c1.028.577 1.028 2.023 0 2.6L15.42 12zM3.609 1.814L15.42 12 3.61 22.186"/></svg>
              <div class="text-left">
                <div class="text-xs uppercase font-medium text-gray-400">Disponible en</div>
                <div class="text-lg font-bold">Google Play</div>
              </div>
            </button>
          </div>
          
          <div class="mt-8 flex items-center justify-center lg:justify-start gap-4 text-sm text-gray-500">
            <div class="flex -space-x-2">
              {[1,2,3,4].map(i => (
                <div class={`w-8 h-8 rounded-full border-2 border-white bg-gray-200 flex items-center justify-center overflow-hidden`}>
                   <span class="text-xs">👤</span>
                </div>
              ))}
            </div>
            <p>+5,000 carnívoros felices</p>
          </div>
        </div>

        <!-- Phone Mockup -->
        <div class="relative z-10 flex items-center justify-center animate-float hidden lg:flex">
          <div class="relative w-[320px] h-[670px] bg-dark rounded-2xl border-[3px] border-gray-900 shadow-2xl shadow-primary/30 overflow-hidden scale-[0.85]">
             <!-- Hole Punch Camera -->
             <div class="absolute top-2 w-3 h-3 bg-black left-1/2 transform -translate-x-1/2 rounded-full z-20 border border-gray-800"></div>
             
             <!-- Screen Content: Video -->
             <div class="w-full h-full bg-black">
                <video 
                  src="https://res.cloudinary.com/dkxj30sue/video/upload/v1766711365/demo_we8irq.mp4" 
                  class="w-full h-full object-cover" 
                  autoplay 
                  loop 
                  muted 
                  playsinline
                ></video>
             </div>
          </div>
          
          <!-- Background Blobs -->
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-primary/20 rounded-full blur-3xl -z-10 animate-pulse-slow"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section id="features" class="py-4">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-base text-primary font-bold tracking-wide uppercase mb-2">Características</h2>
        <p class="text-5xl font-extrabold text-dark mb-4"><img src="/mas.png" alt="Mas" class="w-16 h-16 inline"> que una app de delivery <br> <img src="/mas.png" alt="Mas" class="w-16 h-16 inline"> que una carnicería</p>
        <p class="text-2xl text-gray-600">Tecnología para darle la mejor experiencia de compra al cliente.</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {[
          {
            title: "Optimización del uso de recursos",
            desc: "Mantener un local comercial abierto, con empleados esperando que los clientes entren es un costo enorme. Con Carniapp los clientes compran on line para recibir o retirar y el canal de comunicación con sus clientes es exclusivo y siempre abierto.",
            icon: "/reloj.png"
          },
          {
            title: "Comercio moderno",
            desc: "Carniapp impulsa y acelera el crecimiento de tu negocio. Una app dedicada mejora ventas, agiliza pedidos, reduce errores y fideliza clientes con promociones y notificaciones. La tecnología asegura eficiencia, competitividad y una experiencia de compra superior.",
            icon: "/app.png"
          },
          {
            title: "Marketing inteligente",
            desc: "Las decisiones de marketing se basan en datos y análisis, lo que permite a los comercios personalizar estrategias para atraer y retener más clientes.\nLa aplicación es un servicio para sus clientes.",
            icon: "/intelligence.png"
          },
          /*
          {
            title: "Envíos y retiros",
            desc: "Recibe tu pedido en menos de 2 horas o programa la entrega cuando quieras.",
            icon: "/delivery.png"
          },
          */
          {
            title: "+ retencion y recurrencia",
            desc: "El 87% de los consumidores habituales de carne compra donde le queda más cómodo y la compra en línea es la que más gusta. Según nuestras encuestas.\nEs lo que brinda Carniapp a sus clientes, comprar más comodamente.",
            icon: "/retencion.png"
          },
          /*{
            title: "Práctico y cómodo",
            desc: "Describe aquí tu nueva funcionalidad increíble para los clientes.",
            icon: "/practico.png"
          },*/
          {
            title: "+ rentabilidad + alcance",
            desc: "Carniapp digitaliza su negocio, puede acotar horarios de apertura, reducción de tiempos muertos del personal, + ventas + eficiencia + ganancias. \nLlegue a gente más allá de los límites barriales",
            icon: "/rentabilidad.png"
          },
          {
            title: "Envíos y retiros",
            desc: "Carniapp puede enviar los pedidos a domicilio o a un punto de retiro. Con tracking del envío y optimizacion de rutas.",
            icon: "/delivery.png"
          }
        ].map(feature => (
          <div class="bg-white p-8 rounded-2xl shadow-lg shadow-primary/30 border border-gray-100 hover:shadow-xl hover:shadow-primary/30 transition-all hover:transform hover:-translate-y-1 group">
            <div class={`w-14 h-14 rounded-xl flex items-center justify-center text-3xl mb-6 group-hover:scale-110 transition-transform ${feature.icon.endsWith('.png') ? 'bg-transparent mx-auto' : 'bg-yellow-100'}`}>
              {feature.icon.endsWith('.png') ? (
                <img src={feature.icon} alt={feature.title} class="w-full h-full object-contain scale-[1.15]" />
              ) : (
                feature.icon
              )}
            </div>
            <h3 class="text-xl font-bold text-dark mb-3">{feature.title}</h3>
            <p class="text-gray-600 leading-relaxed whitespace-pre-line">{feature.desc}</p>
          </div>
        ))}
      </div>
      
      <!-- New Section: CarniApp se pone tu camiseta -->
      <div class="mt-32 grid lg:grid-cols-2 gap-12 items-center">
        <!-- Text Content -->
        <div class="order-2 lg:order-1">
          <h2 class="text-6xl font-extrabold text-dark mb-6 leading-tight">
            CarniApp se pone <br />
            <span class="text-primary text-8xl">tu camiseta</span>
          </h2>
          <p class="text-2xl text-gray-600 mb-8 leading-relaxed">
            Personalizamos la experiencia para que tu marca brille. Desde los colores hasta el logo, todo está diseñado para que tus clientes sientan que están comprando directamente en su carnicería de confianza, con la tecnología más avanzada.
          </p>
          <ul class="space-y-4">
            {[
              "Personalización de colores y logo",
              "Catálogo autoadministrable",
              "Soporte técnico dedicado 24/7"
            ].map(item => (
              <li class="flex items-center gap-3">
                <div class="w-6 h-6 rounded-full bg-green-100 flex items-center justify-center text-green-600">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                </div>
                <span class="text-gray-700 font-medium">{item}</span>
              </li>
            ))}
          </ul>
        </div>
        
        <!-- Phone Slideshow -->
        <div class="order-1 lg:order-2 flex justify-center">
          <div class="relative w-[280px] h-[590px] bg-dark rounded-2xl border-[3px] border-gray-900 shadow-2xl shadow-primary/30 overflow-hidden">
             <!-- Hole Punch Camera -->
             <div class="absolute top-2 w-3 h-3 bg-black left-1/2 transform -translate-x-1/2 rounded-full z-20 border border-gray-800"></div>
             
             <!-- Slideshow Container -->
             <div class="relative w-full h-full bg-gray-100">
               <img src="/screen1.png" alt="Screen 1" class="absolute inset-0 w-full h-full object-cover animate-slideshow" style="animation-delay: 0s;" />
               <img src="/screen2.png" alt="Screen 2" class="absolute inset-0 w-full h-full object-cover animate-slideshow" style="animation-delay: 3s;" />
               <img src="/screen3.png" alt="Screen 3" class="absolute inset-0 w-full h-full object-cover animate-slideshow" style="animation-delay: 6s;" />
             </div>
          </div>
        </div>
      </div>

      <!-- Información importante -->
        <div class="flex mt-8 justify-center p-5">
          <img src="/concepto.jpg" alt="Información importante" class="max-w-full h-auto rounded-2xl" />
        </div>

    </div>
  </section>

  <!-- Secondary Features Section -->
  <section class="py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-base text-primary font-bold tracking-wide uppercase mb-2">Cómo trabajamos</h2>
        <p class="text-6xl font-extrabold text-dark mb-4"><span class="text-primary">Carniapp</span> se adapta a vos</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {[
          {
            title: "100% gestionado",
            desc: "Nosotros nos encargamos de todo el marketing de tu marca, cargas el stock disponible y nos encargamos de vender, como si fuesemos uno más en el mostrador con tu marca, la app 100% dedicada a vos.",
            icon: "/personal.png"
          },
          {
            title: "Servicio de software",
            desc: "Te alquilamos el softaware 100% personalizado. Vos y tu equipo se encargan de todo o tu agencia de marketing de confianza.",
            icon: "/software.png"
          },
          {
            title: "Carnicero virtual totalmente personalizable",
            desc: "Las opciones y nombres de los cortes de carne son 100% personalizados para los usos y costumbres del lugar donde trabajes.",
            icon: "/lenguas.png"
          }
        ].map(feature => (
          <div class="bg-white p-8 rounded-2xl shadow-lg shadow-primary/30 border border-gray-100 hover:shadow-xl hover:shadow-primary/30 transition-all hover:transform hover:-translate-y-1 group">
            <div class={`w-14 h-14 rounded-xl flex items-center justify-center text-3xl mb-6 group-hover:scale-110 transition-transform ${feature.icon.endsWith('.png') ? 'bg-transparent mx-auto' : 'bg-yellow-100 mx-auto'}`}>
              {feature.icon.endsWith('.png') ? (
                <img src={feature.icon} alt={feature.title} class="w-full h-full object-contain scale-[1.15]" />
              ) : (
                feature.icon
              )}
            </div>
            <h3 class="text-xl font-bold text-dark mb-3">{feature.title}</h3>
            <p class="text-gray-600 leading-relaxed whitespace-pre-line">{feature.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-dark text-white py-12 border-t border-gray-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid md:grid-cols-4 gap-8">
      <div class="col-span-2">
        <div class="flex items-center gap-2 mb-4">
           <!--  <span class="text-3xl">🥩</span> --><span class="font-bold text-2xl">CarniApp</span>
        </div>
        <p class="text-gray-400 max-w-xs mb-6">
          La revolución de la carne. Calidad, tecnología y pasión por el asado en una sola app.
        </p>
      </div>
      <div>
        <h4 class="font-bold text-lg mb-4">Legal</h4>
        <ul class="space-y-2 text-gray-400">
          <li><a href="#" class="hover:text-primary transition-colors">Términos y Condiciones</a></li>
          <li><a href="/privacidad" class="hover:text-primary transition-colors">Privacidad</a></li>
        </ul>
      </div>
      <div>
        <h4 class="font-bold text-lg mb-4">Seguinos</h4>
        <div class="flex space-x-4">
           <a href="#" class="w-10 h-10 bg-gray-800 rounded-full flex items-center justify-center hover:bg-primary hover:text-dark transition-all font-bold">IG</a>
           <a href="#" class="w-10 h-10 bg-gray-800 rounded-full flex items-center justify-center hover:bg-primary hover:text-dark transition-all font-bold">FB</a>
        </div>
      </div>
    </div>
    <div class="border-t border-gray-800 mt-12 pt-8 text-center text-gray-500 text-sm">
      &copy; {new Date().getFullYear()} CarniApp.
    </div>
  </footer>
</Layout>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-20px); }
  }
  .animate-float {
    animation: float 6s ease-in-out infinite;
  }
  
  @keyframes pulse-slow {
    0%, 100% { opacity: 0.2; transform: translate(-50%, -50%) scale(1); }
    50% { opacity: 0.3; transform: translate(-50%, -50%) scale(1.1); }
  }
  .animate-pulse-slow {
    animation: pulse-slow 4s ease-in-out infinite;
  }
  
  @keyframes slideshow {
    0% { opacity: 0; }
    10% { opacity: 1; }
    40% { opacity: 1; }
    50% { opacity: 0; }
    100% { opacity: 0; }
  }
  .animate-slideshow {
    animation: slideshow 9s infinite;
  }
</style>
